generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  status       String   @default("offline")
  locationId   String?  @map("location_id")
  role         String   @default("team_member")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  location       Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)
  messages       Message[]
  channelMembers ChannelMember[]
  conversationMembers ConversationMember[]
  channelsCreated Channel[] @relation("ChannelCreator")
  readReceipts   ReadReceipt[]
  reactions      Reaction[]
  shifts         Shift[]
  feedPosts      FeedPost[]
  feedReactions  FeedReaction[]
  praiseGiven    Praise[]       @relation("PraiseGiven")
  praiseReceived Praise[]       @relation("PraiseReceived")
  hourlyRate     Float?         @map("hourly_rate")
  payPeriods     PayPeriod[]

  @@map("users")
}

model Channel {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isPrivate   Boolean  @default(false) @map("is_private")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator  User            @relation("ChannelCreator", fields: [createdBy], references: [id])
  members  ChannelMember[]
  messages Message[]
  readReceipts ReadReceipt[]

  @@map("channels")
}

model ChannelMember {
  channelId String   @map("channel_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@map("channel_members")
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  members  ConversationMember[]
  messages Message[]
  readReceipts ReadReceipt[]

  @@map("conversations")
}

model ConversationMember {
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String    @id @default(uuid())
  content        String
  authorId       String    @map("author_id")
  channelId      String?   @map("channel_id")
  conversationId String?   @map("conversation_id")
  threadParentId String?   @map("thread_parent_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  editedAt       DateTime? @map("edited_at")

  author       User          @relation(fields: [authorId], references: [id])
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  threadParent Message?      @relation("ThreadReplies", fields: [threadParentId], references: [id])
  threadReplies Message[]    @relation("ThreadReplies")
  reactions    Reaction[]

  @@map("messages")
}

model Reaction {
  id        String   @id @default(uuid())
  emoji     String
  userId    String   @map("user_id")
  messageId String   @map("message_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@map("reactions")
}

model ReadReceipt {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  channelId        String?  @map("channel_id")
  conversationId   String?  @map("conversation_id")
  lastReadMessageId String  @map("last_read_message_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@unique([userId, conversationId])
  @@map("read_receipts")
}

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]
  shifts    Shift[]

  @@map("locations")
}

model Shift {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  locationId String   @map("location_id")
  date       DateTime @db.Date
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  role       String
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model FeedPost {
  id            String   @id @default(uuid())
  authorId      String   @map("author_id")
  type          String   @default("announcement")
  title         String?
  content       String
  imageUrl      String?  @map("image_url")
  locationScope String   @default("all") @map("location_scope")
  isPinned      Boolean  @default(false) @map("is_pinned")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions FeedReaction[]
  praise    Praise?

  @@map("feed_posts")
}

model FeedReaction {
  id         String   @id @default(uuid())
  emoji      String
  userId     String   @map("user_id")
  feedPostId String   @map("feed_post_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedPost FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)

  @@unique([userId, feedPostId, emoji])
  @@map("feed_reactions")
}

model Praise {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  message    String
  category   String?
  feedPostId String?  @unique @map("feed_post_id")
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User      @relation("PraiseGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User      @relation("PraiseReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  feedPost FeedPost? @relation(fields: [feedPostId], references: [id], onDelete: SetNull)

  @@map("praises")
}

model PayPeriod {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  payDate     DateTime @map("pay_date") @db.Date
  hoursWorked Float    @map("hours_worked")
  hourlyRate  Float    @map("hourly_rate")
  grossPay    Float    @map("gross_pay")
  netPay      Float    @map("net_pay")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee User @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("pay_periods")
}
