    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.4",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "prisma": "^6.4.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
